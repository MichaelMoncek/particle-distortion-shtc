@article{exp-external-rev,
title = {Electric field-intensified chemical processes and reaction chemistry},
journal = {Current Opinion in Chemical Engineering},
volume = {39},
pages = {100895},
year = {2023},
issn = {2211-3398},
doi = {https://doi.org/10.1016/j.coche.2022.100895},
url = {https://www.sciencedirect.com/science/article/pii/S2211339822001058},
author = {Nan Wang and Laurence Weatherley},
abstract = {Electric fields (EFs) represent an important resource that can be utilized for process intensification in the chemical industry. The impacts of EFs on atoms, molecules, particles, and complex matter can vary significantly and trigger a range of potential new technologies for industrial applications. Mass and heat transfer intensification and control of reaction rate, reactivity, and selectivity are long-standing goals and challenges in the chemical industry. Utilization of EFs provides an efficient and cost-effective way for intensified chemical processing and reaction chemistry, while more efforts are required to gain more understanding of the complex phenomena and effects stimulated by EFs. In this paper, the impacts of novel electrically induced intensification of mass and heat transfer are reviewed, with discussion focusing on liquid–liquid systems, gas–solid–liquid systems, and electrohydrodynamic enhancement of heat transfer. The implications for the performance improvement of chemical reactions in multiphase systems are highlighted with some recent examples.}
}

