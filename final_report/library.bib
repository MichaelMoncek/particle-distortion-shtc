@Article{	  ruggeri1989,
  author	= "Ruggeri, T.",
  title		= "Galilean invariance and entropy principle for systems of
		  balance laws",
  journal	= "Continuum Mechanics and Thermodynamics",
  year		= "1989",
  month		= "Feb",
  day		= "01",
  volume	= "1",
  number	= "1",
  pages		= "3--20",
  abstract	= "The Galilean invariance of a generic system of balance
		  laws dictates a specific dependence of the densities and
		  fluxes on velocity. Thus these quantities decompose in a
		  unique manner into convective and non-convetive parts. Such
		  a decomposition permits the elimination of velocity
		  dependencies in the entropy principle, which becomes a
		  constraint on the constitutive functions only. These
		  results clarify the mathematical structure of extended
		  thermodynamics. They also provide a connection between the
		  equations of continuum thermodynamics and the Boltzmann
		  equation.",
  issn		= "1432-0959",
  doi		= "10.1007/BF01125883",
  url		= "https://doi.org/10.1007/BF01125883"
}

